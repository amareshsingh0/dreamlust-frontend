# Environment
NODE_ENV=development
PORT=3001

# Database (Required)
DATABASE_URL=postgresql://user:password@localhost:5432/dreamlust

# JWT Authentication (Required)
JWT_SECRET=your-very-secure-jwt-secret-at-least-32-characters-long
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Supabase (Optional - for additional features)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Redis (Optional - for caching and session management)
REDIS_URL=redis://localhost:6379

# OAuth Providers (Optional)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
TWITTER_CLIENT_ID=your-twitter-client-id
TWITTER_CLIENT_SECRET=your-twitter-client-secret

# App URLs
FRONTEND_URL=http://localhost:4001
API_URL=http://localhost:3001

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS_USER=100
RATE_LIMIT_MAX_REQUESTS_IP=1000

# File Storage - Choose one: Cloudflare R2 (recommended) or AWS S3
# Cloudflare R2
R2_ACCOUNT_ID=your-r2-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=your-r2-bucket-name
R2_PUBLIC_URL=https://your-r2-public-url.com

# AWS S3 (Alternative to R2)
S3_ENDPOINT=https://s3.amazonaws.com
S3_ACCESS_KEY_ID=your-s3-access-key-id
S3_SECRET_ACCESS_KEY=your-s3-secret-access-key
S3_BUCKET_NAME=your-s3-bucket-name
S3_REGION=us-east-1
S3_CDN_URL=https://your-cdn-url.com

# Video Hosting - Choose one: Mux (recommended) or Cloudflare Stream
# Mux
MUX_TOKEN_ID=your-mux-token-id
MUX_TOKEN_SECRET=your-mux-token-secret
MUX_SIGNING_KEY=your-mux-signing-key
MUX_SIGNING_KEY_ID=your-mux-signing-key-id

# Cloudflare Stream (Alternative to Mux)
CLOUDFLARE_STREAM_API_TOKEN=your-cloudflare-stream-token
CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-email-password
SMTP_FROM=noreply@dreamlust.com

# Payment Gateway - Razorpay (Primary)
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret
RAZORPAY_BASIC_PLAN_ID=plan_basic_id
RAZORPAY_PREMIUM_PLAN_ID=plan_premium_id
RAZORPAY_PRO_PLAN_ID=plan_pro_id

# Alternative Payment Gateways (Optional)
# Stripe (Legacy - deprecated)
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
STRIPE_PUBLISHABLE_KEY=pk_test_your-publishable-key

# PayPal (Alternative)
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-client-secret

# Push Notifications (VAPID)
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:your-email@example.com

# Monitoring & Error Tracking
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_RELEASE=1.0.0
SENTRY_SERVER_NAME=api-server

# Datadog APM (Optional - alternative to Sentry)
DATADOG_API_KEY=your-datadog-api-key
DATADOG_APP_KEY=your-datadog-app-key
DD_SITE=datadoghq.com
DD_ENV=development
DD_SERVICE=dreamlust-api
DD_VERSION=1.0.0

# Security
ENCRYPTION_KEY=your-32-character-encryption-key

# Logging
LOG_LEVEL=info

# Alerting & Incident Response (Optional)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your-webhook-url
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your-webhook-url
PAGERDUTY_INTEGRATION_KEY=your-pagerduty-integration-key
OPSGENIE_API_KEY=your-opsgenie-api-key

# Image Classification (Optional - for content moderation)
# AWS Rekognition
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=us-east-1

# Google Cloud Vision (Alternative to AWS Rekognition)
GOOGLE_CLOUD_PROJECT_ID=your-gcp-project-id
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
