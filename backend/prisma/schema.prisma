  overallFeedback String?   @map("overall_feedback") @db.Text
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  resolvedAt      DateTime? @map("resolved_at") @db.Timestamp(6)
  updatedAt       DateTime  @default(now()) @map("updated_at") @db.Timestamp(6)

  comments ContentReviewComment[]

  @@index([contentId, status], map: "idx_content_reviews_content_status")
  @@index([contentId], map: "idx_content_reviews_content")
  @@index([reviewerId], map: "idx_content_reviews_reviewer")
  @@index([status], map: "idx_content_reviews_status")
  @@map("content_reviews")
}

model ContentReviewComment {
  id        String   @id @default(cuid())
  reviewId  String   @map("review_id")
  timestamp Int
  comment   String   @db.Text
  type      String
  resolved  Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt DateTime @default(now()) @map("updated_at") @db.Timestamp(6)

  review ContentReview @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@index([reviewId, timestamp], map: "idx_content_review_comments_review_timestamp")
  @@index([reviewId], map: "idx_content_review_comments_review")
  @@index([resolved], map: "idx_content_review_comments_resolved")
  @@map("content_review_comments")
}

model Translation {
  id           String   @id @default(cuid())
  entityType   String   @map("entity_type")
  entityId     String   @map("entity_id")
  language     String
  field        String
  value        String   @db.Text
  translatedBy String   @map("translated_by")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt    DateTime @default(now()) @map("updated_at") @db.Timestamp(6)

  @@unique([entityType, entityId, language, field], map: "translations_unique")
  @@index([entityType, entityId], map: "idx_translations_entity")
  @@index([language], map: "idx_translations_language")
  @@map("translations")
}